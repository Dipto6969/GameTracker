# ═══════════════════════════════════════════════════════════════════
# GameTracker Environment Variables
# Copy this file to .env.local and fill in the values
# ═══════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────
# CLOUDINARY (for Screenshots feature)
# Get these from: https://cloudinary.com (free tier available)
# ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your-upload-preset

# ─────────────────────────────────────────────────────────────────────
# GAMING NEWS API (for Gaming News section)
# Get a free API key from: https://newsapi.org
# Free tier: 100 requests/day (we cache aggressively to stay under limit)
# ─────────────────────────────────────────────────────────────────────
NEWS_API_KEY=your-newsapi-key

# ─────────────────────────────────────────────────────────────────────
# VERCEL KV (for production data storage)
# Automatically provided by Vercel when you add KV storage
# ─────────────────────────────────────────────────────────────────────
# KV_URL=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# KV_REST_API_READ_ONLY_TOKEN=

# ─────────────────────────────────────────────────────────────────────
# RAWG API (for game data - optional, uses public endpoint by default)
# Get from: https://rawg.io/apidocs
# ─────────────────────────────────────────────────────────────────────
# RAWG_API_KEY=your-rawg-api-key
